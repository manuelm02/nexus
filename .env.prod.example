# 生产环境：可以与 dev 共用外部基础设施实例，但必须使用独立数据库和 Redis 命名空间。
NEXUS_ENV_FILE=.env.prod

DB_HOST=your-prod-postgres-host
DB_PORT=5432
DB_NAME=nexus_prod
DB_USER=nexus
DB_PASSWORD=your_prod_db_password_here

REDIS_HOST=your-prod-redis-host
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_KEY_PREFIX=nexus:prod:

CRAWL4AI_ENABLED=true
CRAWL4AI_BASE_URL=http://your-prod-crawl4ai-host:11235

JWT_SECRET=your_prod_jwt_secret_at_least_32_characters
ENCRYPT_SECRET=your_prod_32_char_encrypt_secret!

OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
JINA_API_KEY=

# 腾讯云机器翻译（可选，留空则不启用快速初稿）
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_TMT_REGION=ap-guangzhou
