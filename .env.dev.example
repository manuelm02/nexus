# 本地调试环境：外部基础设施地址按你的机器或服务器填写。
NEXUS_ENV_FILE=.env.dev

DB_HOST=your-dev-postgres-host
DB_PORT=5432
DB_NAME=nexus_dev
DB_USER=nexus
DB_PASSWORD=your_dev_db_password_here

REDIS_HOST=your-dev-redis-host
REDIS_PORT=6379
REDIS_DATABASE=1
REDIS_KEY_PREFIX=nexus:dev:

CRAWL4AI_ENABLED=true
CRAWL4AI_BASE_URL=http://your-dev-crawl4ai-host:11235

JWT_SECRET=your_dev_jwt_secret_at_least_32_characters
ENCRYPT_SECRET=your_dev_32_char_encrypt_secret!

OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
JINA_API_KEY=
