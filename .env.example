# 数据库（必填）
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=nexus_prod
DB_USER=nexus
DB_PASSWORD=your_db_password_here

# Redis（可选，阶段3使用；dev/prod 用 database 或 key prefix 隔离）
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_KEY_PREFIX=nexus:prod:

# JWT（必填，至少32位随机字符串）
JWT_SECRET=your_jwt_secret_at_least_32_characters_long

# LLM 加密密钥（必填，必须是32位）
ENCRYPT_SECRET=your_32_char_encrypt_secret_here!

# LLM（可选，也可以在设置页面配置）
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Telegram（可选）
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# AnythingLLM（阶段2，Tailscale 内网访问）
ANYTHINGLLM_BASE_URL=http://100.x.x.x:3001
ANYTHINGLLM_API_KEY=

# MinIO（阶段2，Tailscale 内网访问）
MINIO_ENDPOINT=http://100.x.x.x:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=nexus-files

# Notion（可选）
NOTION_TOKEN=
NOTION_FOCUS_DB_ID=
NOTION_FLEETING_DB_ID=
NOTION_MINDBANK_DB_ID=
NOTION_LEDGER_DB_ID=
NOTION_FORGE_DB_ID=
NOTION_RADAR_DB_ID=

# 爬虫（可选）
JINA_API_KEY=
CRAWL4AI_ENABLED=true
CRAWL4AI_BASE_URL=http://your-crawl4ai-host:11235
